generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model CartItem {
  id         Int      @id @default(autoincrement())
  user_id    String
  artwork_id Int
  quantity   Int      @default(1)
  created_at DateTime @default(now())

  artwork    Artwork  @relation(fields: [artwork_id], references: [id])

  @@map("cart_items")
}

model Artwork {
  id          Int        @id @default(autoincrement())
  title       String     @db.VarChar(255)
  description String?    @db.Text
  category    String?    @db.VarChar(100)
  format      String?    @db.VarChar(50)
  price       Decimal    @db.Decimal(10, 2)
  inventory   Int?       @default(1)
  artist_name String?    @db.VarChar(255)
  image_url   String?    @db.Text
  s3_key      String?    @db.VarChar(255)
  creator_sub String?    @db.VarChar(191)
  created_at  DateTime?  @default(now()) @db.Timestamp(0)
  updated_at  DateTime?  @default(now()) @updatedAt @db.Timestamp(0)
 

  cartItems   CartItem[]
  orderItems OrderItem[]
  interactions UserInteraction[]

  @@index([creator_sub])
  @@map("artworks")
}
model Order {
  id                        Int         @id @default(autoincrement())
  user_id                   String
  customer_name             String      @db.VarChar(255)
  phone_number              String      @db.VarChar(50)
  shipping_address_line1    String      @db.VarChar(255)
  shipping_address_line2    String?     @db.VarChar(255)
  shipping_city             String      @db.VarChar(100)
  shipping_postal_code      String      @db.VarChar(30)
  shipping_country          String      @db.VarChar(100)
  subtotal                  Decimal     @db.Decimal(10, 2)
  shipping                  Decimal     @default(0.00) @db.Decimal(10, 2)
  tax                       Decimal     @default(0.00) @db.Decimal(10, 2)
  total                     Decimal     @db.Decimal(10, 2)
  status                    String      @default("PENDING") @db.VarChar(50)
  payment_method            String      @db.VarChar(20)
  payment_status            String      @default("PENDING") @db.VarChar(20)
  stripe_checkout_session_id String?    @db.VarChar(255)
  stripe_payment_intent_id   String?    @db.VarChar(255)
  created_at                DateTime?   @default(now()) @db.Timestamp(0)
  updated_at                DateTime?   @default(now()) @updatedAt @db.Timestamp(0)

  orderItems OrderItem[]

  @@map("orders")
}

model OrderItem {
  id                Int       @id @default(autoincrement())
  order_id          Int
  artwork_id        Int
  quantity          Int       @default(1)
  price_at_purchase Decimal   @db.Decimal(10, 2)
  line_total        Decimal   @db.Decimal(10, 2)
  created_at        DateTime? @default(now()) @db.Timestamp(0)

  order             Order     @relation(fields: [order_id], references: [id])
  artwork           Artwork   @relation(fields: [artwork_id], references: [id])
  payouts           ArtistPayout[]

  @@map("order_items")
}

model ArtistPayout {
  id                 Int       @id @default(autoincrement())
  artist_sub         String    @db.VarChar(191)
  order_item_id      Int
  gross_amount       Decimal   @db.Decimal(10, 2)
  platform_fee       Decimal   @db.Decimal(10, 2)
  artist_amount      Decimal   @db.Decimal(10, 2)
  status             String    @default("PENDING") @db.VarChar(20)
  payment_reference  String?   @db.VarChar(255)
  created_at         DateTime? @default(now()) @db.Timestamp(0)
  paid_at            DateTime? @db.Timestamp(0)

  orderItem          OrderItem @relation(fields: [order_item_id], references: [id])

  @@index([artist_sub])
  @@index([status])
  @@map("artist_payouts")
}

model UserInteraction {
  id         Int       @id @default(autoincrement())
  user_id    String    @db.VarChar(191)
  artwork_id Int
  type       String    @db.VarChar(50)
  created_at DateTime  @default(now())

  artwork    Artwork   @relation(fields: [artwork_id], references: [id], onDelete: Cascade)

  @@unique([user_id, artwork_id, type])
  @@index([user_id])
  @@index([artwork_id])
  @@index([type])
  @@map("user_interactions")
}

model ArtistProfile {
  id          Int       @id @default(autoincrement())
  creator_sub String    @unique @db.VarChar(191)
  applicant_email String? @db.VarChar(255)
  display_name String   @db.VarChar(255)
  bio         String    @db.Text
  avatar_url  String?   @db.Text
  location    String?   @db.VarChar(255)
  website     String?   @db.VarChar(255)
  instagram   String?   @db.VarChar(255)
  application_status String @default("PENDING") @db.VarChar(20)
  reviewed_at DateTime? @db.Timestamp(0)
  reviewed_by String?   @db.VarChar(191)
  rejection_reason String? @db.Text
  is_published Boolean  @default(true)
  is_featured Boolean   @default(false)
  created_at  DateTime? @default(now()) @db.Timestamp(0)
  updated_at  DateTime? @default(now()) @updatedAt @db.Timestamp(0)

  @@index([application_status])
  @@index([is_published])
  @@index([is_featured])
  @@map("artist_profiles")
}
